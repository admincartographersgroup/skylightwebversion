{
  "name": "skylight-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Skylight, rebuilt as a zero-backend static web app: point a browser at the sky above you and project it on the ceiling. No Pi, no radio, no server.",
  "scripts": {
    "postinstall": "node scripts/make-icons.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "make-icons": "node scripts/make-icons.mjs"
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "satellite.js": "^5.0.0",
    "tz-lookup": "^6.1.25"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1"
  }
}
